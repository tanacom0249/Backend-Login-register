// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider = "mysql"
}

enum Role {
    Seller
    Buyer
}

model User {
    id       Int     @id @default(autoincrement())
    firstName String
    lastName String
    username String
    email    String  @unique
    password String
    role     Role    @default(Buyer)
    street   String?
    city     String?
    state    String?
    country  String?
    Suite    String?
    postalCode String?
    
    // --- ส่วนที่ต้องเพิ่มสำหรับ OTP ---
  resetOtp        String?   // เก็บเลข OTP 6 หลัก
  resetOtpExpires DateTime? // เก็บเวลาหมดอายุของ OTP
  // ------------------------------

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
}
